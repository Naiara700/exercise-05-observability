{
  "title": "Node Registry",
  "uid": "noderegistry",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP Request Rate",
      "id": 1,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_requests_total[1m])",
          "legendFormat": "{{method}} {{path}} {{status_code}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "P95 Request Duration",
      "id": 2,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[1m]))",
          "legendFormat": "{{method}} {{path}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Active Nodes",
      "id": 3,
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [{ "expr": "api_active_nodes", "refId": "A" }]
    }
  ]
}
